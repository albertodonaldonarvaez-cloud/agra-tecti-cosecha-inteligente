<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AgraFieldApp" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Colores base del tema -->
        <item name="android:colorPrimary">#16a34a</item>
        <item name="android:colorPrimaryDark">#15803d</item>
        <item name="android:colorAccent">#22c55e</item>
        <!-- Edge-to-edge: transparent system bars for Compose to draw behind -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
